[debug] [2026-05-17T14:54:17.952Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/spk-saw-c377c/rulesets {"name":"projects/spk-saw-c377c/rulesets/29ae12ec-192c-4277-82c8-fd61cda2d16d","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Criteria: only the owner can read, create, update, or delete\n    match /criteria/{docId} {\n      allow read, update, delete: if request.auth != null\n                                  && request.auth.uid == resource.data.uid;\n      allow create: if request.auth != null\n                    && request.resource.data.uid == request.auth.uid;\n    }\n\n    // Alternatives: only the owner can read, create, update, or delete\n    match /alternatives/{docId} {\n      allow read, update, delete: if request.auth != null\n                                  && request.auth.uid == resource.data.uid;\n      allow create: if request.auth != null\n                    && request.resource.data.uid == request.auth.uid;\n    }\n\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-17T14:54:17.513343Z","metadata":{"services":["cloud.firestore"]}}
